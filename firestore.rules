rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: meetings
    // Document ID: auto-generated
    // Fields:
    //   - date: string (ISO 8601)
    //   - title: string (max 200 chars)
    //   - userId: string (matches auth.uid)
    //   - report: map (MeetingReport schema)
    //   - createdAt: timestamp
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - displayName: string
    //   - theme: string (light|dark)
    //   - defaultMode: string (mic|system)
    //   - language: string
    //   - summaryDetail: string (concise|detailed)
    //   - role: string (user|admin)
    //   - email: string
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             ((request.auth.token.email == "brunnofilipe@gmail.com" && request.auth.token.email_verified == true) || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['date', 'title', 'userId', 'report']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.date is string &&
             data.report is map &&
             data.report.summary is string &&
             data.report.highlights is list &&
             data.report.nextActions is list &&
             data.report.keyDecisions is list &&
             data.report.transcript is list;
    }

    function isValidUser(data) {
      return data.keys().hasAny(['displayName', 'theme', 'defaultMode', 'language', 'summaryDetail', 'role', 'email']) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('theme' in data) || data.theme in ['light', 'dark']) &&
             (!('defaultMode' in data) || data.defaultMode in ['mic', 'system']) &&
             (!('summaryDetail' in data) || data.summaryDetail in ['concise', 'detailed']);
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidMeeting(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidMeeting(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
